{% if screenshots %}
  <div{{ attributes.addClass('field--game-screenshots') }}>
    {% if not label_hidden %}
      <div class="field__label">{{ label }}</div>
    {% endif %}
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2 mt-2">
      {% for key, shot in screenshots %}
        {%- set modal_id = 'screenshot-modal-' ~ key -%}

        <button
          type="button"
          data-hs-overlay="#{{ modal_id }}"
          class="block overflow-hidden rounded focus:outline-none"
        >
          <img
            src="{{ shot.thumbnail_url }}"
            alt="{{ shot.alt }}"
            class="w-full h-24 object-cover hover:opacity-80 transition-opacity rounded"
          />
        </button>

        <div
          id="{{ modal_id }}"
          class="hs-overlay hidden size-full fixed top-0 start-0 z-[80] overflow-x-hidden overflow-y-auto pointer-events-none"
          role="dialog"
          tabindex="-1"
          aria-labelledby="{{ modal_id }}-label"
        >
          <div class="hs-overlay-open:mt-7 hs-overlay-open:opacity-100 hs-overlay-open:duration-300 mt-0 opacity-0 ease-out transition-all max-w-4xl w-full m-3 mx-auto">
            <div class="flex flex-col bg-base-100 border border-base-300 shadow-xl rounded-xl pointer-events-auto">
              <div class="flex justify-end p-2">
                <button
                  type="button"
                  class="btn btn-sm btn-circle btn-ghost"
                  data-hs-overlay="#{{ modal_id }}"
                  aria-label="Close"
                >✕</button>
              </div>
              <div class="px-4 pb-4">
                <img
                  src="{{ shot.full_url }}"
                  alt="{{ shot.alt }}"
                  class="w-full h-auto rounded"
                />
                {% if shot.alt %}
                  <p class="text-center text-sm mt-2 opacity-70">{{ shot.alt }}</p>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
{% endif %}
