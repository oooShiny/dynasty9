<?php

/**
 * @file
 * Primary module hooks for Dynasty Voicemail.
 */

use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_help().
 */
function dynasty_voicemail_help($route_name, RouteMatchInterface $route_match) {
  switch ($route_name) {
    case 'help.page.dynasty_voicemail':
      $output = '<h3>' . t('About') . '</h3>';
      $output .= '<p>' . t('Allows podcast listeners to record and submit audio voicemail messages.') . '</p>';
      return $output;
  }
}

/**
 * Implements hook_theme().
 */
function dynasty_voicemail_theme($existing, $type, $theme, $path) {
  return [
    'voicemail_recorder' => [
      'variables' => [
        'max_duration' => 120,
        'csrf_token' => '',
        'honeypot_enabled' => TRUE,
      ],
      'template' => 'voicemail-recorder',
    ],
  ];
}

/**
 * Implements hook_mail().
 */
function dynasty_voicemail_mail($key, &$message, $params) {
  switch ($key) {
    case 'voicemail_notification':
      $message['subject'] = t('New Voicemail from @name', ['@name' => $params['name']]);
      $message['body'][] = t('A new voicemail has been submitted.');
      $message['body'][] = '';
      $message['body'][] = t('From: @name', ['@name' => $params['name']]);
      $message['body'][] = t('Email: @email', ['@email' => $params['email']]);
      $message['body'][] = t('Duration: @duration seconds', ['@duration' => $params['duration']]);
      $message['body'][] = t('Submitted: @date', ['@date' => $params['date']]);
      $message['body'][] = '';
      $message['body'][] = t('Listen to the voicemail:');
      $message['body'][] = $params['file_url'];
      break;
  }
}
